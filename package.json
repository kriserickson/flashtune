{
  "name": "flashtune",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "lint": "vp lint -c .oxlintrc.json",
    "lint:fix": "vp lint -c .oxlintrc.json --fix",
    "format": "vp fmt",
    "start": "node build",
    "preview": "vp preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && tsgo --noEmit -p ./tsconfig.json",
    "seed:songs": "node scripts/fetch-images.mjs",
    "stats": "node scripts/stats.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "svelte": "^5.55.2",
    "svelte-dnd-action": "^0.9.69",
    "vite": "^8.0.7",
    "vite-plus": "^0.1.19",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@9.15.0"
}
